{
  "entities": {
    "Participation": {
      "title": "Participation",
      "description": "A performance entry for the event",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Performance title"
        },
        "description": {
          "type": "string",
          "description": "Performance description"
        },
        "participants": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of participant names"
        },
        "group_type": {
          "type": "string",
          "enum": ["Single", "Duo", "Group"],
          "description": "Type of participation"
        },
        "category": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Performance categories"
        },
        "media_url": {
          "type": "string",
          "description": "URL to media attachment"
        },
        "media_type": {
          "type": "string",
          "enum": ["link", "mp3", "mp4", "image"],
          "description": "Type of media"
        },
        "contact_info": {
          "type": "string",
          "description": "Contact information (Phone/Email)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of submission"
        },
        "uid": {
          "type": "string",
          "description": "User ID of the submitter"
        },
        "program": {
          "type": "string",
          "description": "Selected program name"
        },
        "program_id": {
          "type": "string",
          "description": "Selected program ID"
        }
      },
      "required": ["title", "description", "participants", "group_type", "category", "contact_info", "createdAt"]
    },
    "Program": {
      "title": "Program",
      "description": "Configuration for different events/programs",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "subtitle": { "type": "string" },
        "gifUrl": { "type": "string" },
        "invitationUrl": { "type": "string" },
        "invitationPdfUrl": { "type": "string" },
        "isActive": { "type": "boolean" },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "time": { "type": "string" },
        "description": { "type": "string" },
        "highlights": { "type": "array", "items": { "type": "string" } },
        "dressCode": { "type": "string" },
        "department": { "type": "string" },
        "footerText": { "type": "string" },
        "countdownDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "gifUrl", "invitationUrl", "isActive", "createdAt"]
    },
    "Wish": {
      "title": "Wish",
      "description": "Wishing wall post card submission",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the well wisher" },
        "message": { "type": "string", "description": "Wish message text" },
        "color": { "type": "string", "description": "Sticky card background color code" },
        "ink": { "type": "string", "description": "Ink text color code" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorSessionId": { "type": "string", "description": "Unguessable secret session ID of the writer" },
        "isDeleted": { "type": "boolean", "description": "Whether the wish is soft-deleted" },
        "programId": { "type": "string", "description": "The active program id that this wish belongs to" }
      },
      "required": ["name", "message", "createdAt"]
    },
    "VipPass": {
      "title": "VipPass",
      "description": "Serialized custom VIP entry passport with check-in verification",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the VIP guest" },
        "qr_code": { "type": "string", "description": "Unique serialized passport signature" },
        "is_validated": { "type": "boolean", "description": "Check-in validation state" },
        "validated_at": { "type": "string", "format": "date-time", "description": "Check-in time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "qr_code", "is_validated", "createdAt"]
    }
  },
  "firestore": {
    "/participations/{participationId}": {
      "schema": "Participation",
      "description": "Collection of event participations"
    },
    "/programs/{programId}": {
      "schema": "Program",
      "description": "Collection of event configurations"
    },
    "/wishes/{wishId}": {
      "schema": "Wish",
      "description": "Wishing wall notes"
    },
    "/vip_passes/{passId}": {
      "schema": "VipPass",
      "description": "Collection of VIP passes with validation"
    }
  }
}
