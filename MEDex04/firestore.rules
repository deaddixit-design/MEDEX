rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "sksafin361@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Validation for Participations
    function isValidParticipation(data) {
      return data.keys().hasAll(['title', 'description', 'participants', 'group_type', 'category', 'contact_info', 'created_at', 'createdAt', 'performer']) &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.participants is list && data.participants.size() <= 50 &&
             data.group_type in ['Single', 'Duo', 'Group'] &&
             data.category is list &&
             data.contact_info is string && data.contact_info.size() <= 500 &&
             data.performer is string &&
             data.created_at is string &&
             (!('program' in data) || (data.program is string && data.program.size() <= 200)) &&
             (!('program_id' in data) || (data.program_id is string && data.program_id.size() <= 100)) &&
             (data.createdAt == request.time || data.createdAt == null);
    }

    // Validation for Messages
    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'subject', 'message', 'created_at', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() <= 500 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 5000 &&
             data.status in ['unread', 'read'] &&
             (data.created_at == request.time || data.created_at == null);
    }

    // Validation for Wishes
    function isValidWish(data) {
      return data.keys().hasAll(['name', 'message', 'color', 'ink', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 1000 &&
             data.color is string &&
             data.ink is string &&
             (!('authorSessionId' in data) || (data.authorSessionId is string && data.authorSessionId.size() <= 100)) &&
             (!('isDeleted' in data) || data.isDeleted is bool) &&
             (!('programId' in data) || (data.programId is string && data.programId.size() <= 100));
    }

    // Validation for VIP Passes
    function isValidVipPass(data) {
      return data.keys().hasAll(['name', 'qr_code', 'is_validated', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.qr_code is string && data.qr_code.size() > 0 &&
             data.is_validated is bool;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /participations/{participationId} {
      // Allow anyone (authenticated or not) to submit participation
      allow create: if isValidParticipation(incoming());
      
      // List/Get/Update/Delete restricted to admins
      allow read, list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      // Allow anyone to send contact messages
      allow create: if isValidMessage(incoming());
      
      // List/Get/Update/Delete restricted to admins
      allow read, list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Test connection path
    match /test/connection {
      allow read: if true;
    }

    // Programs Collection
    match /programs/{programId} {
      // Anyone can read programs (to see current event details)
      allow read: if true;
      allow list: if true;
      
      // Only admins can create/update/delete
      allow create, update, delete: if isAdmin();
    }

    // Wishes Collection
    match /wishes/{wishId} {
      // Anyone can read or write a well-wish card
      allow read, list: if true;
      allow create: if isValidWish(incoming());
      
      // Allow update if admin, or if the writer is soft-deleting with secret token confirmation
      allow update: if isAdmin() || (
        isValidWish(incoming()) &&
        incoming().authorSessionId == existing().authorSessionId &&
        incoming().isDeleted == true
      );
      
      // Only admins can completely hard delete
      allow delete: if isAdmin();
    }

    // VIP Passes Collection
    match /vip_passes/{passId} {
      // Complete read/write is only for authorized admins
      allow read, list, create, update, delete: if isAdmin();
    }
  }
}
