<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" width="100%" height="100%">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#023047" />
      <stop offset="50%" stop-color="#005ca9" />
      <stop offset="100%" stop-color="#051923" />
    </linearGradient>
    <linearGradient id="greenGlow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1faf38" stop-opacity="0.35" />
      <stop offset="100%" stop-color="#0e6d1e" stop-opacity="0" />
    </linearGradient>
    <linearGradient id="book1" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#0a5c36" />
      <stop offset="100%" stop-color="#12b365" />
    </linearGradient>
    <linearGradient id="book2" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#1e3a8a" />
      <stop offset="100%" stop-color="#3b82f6" />
    </linearGradient>
    <linearGradient id="book3" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#581c87" />
      <stop offset="100%" stop-color="#a855f7" />
    </linearGradient>
    <linearGradient id="book4" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#701a75" />
      <stop offset="100%" stop-color="#d946ef" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1920" height="1080" fill="url(#bg)" />
  <circle cx="200" cy="800" r="450" fill="url(#greenGlow)" filter="blur(80px)" />
  <circle cx="1600" cy="300" r="400" fill="#005ca9" opacity="0.3" filter="blur(100px)" />

  <!-- Grid Pattern -->
  <g opacity="0.04" stroke="#ffffff" stroke-width="1">
    <pattern id="grid" width="80" height="80" patternUnits="userSpaceOnUse">
      <rect width="80" height="80" fill="none" />
      <path d="M 80 0 L 0 0 0 80" fill="none" />
    </pattern>
    <rect width="100%" height="100%" fill="url(#grid)" />
  </g>

  <!-- Left Side Text and Features (Powerful Academic Utilities & Archives) -->
  <g transform="translate(150, 180)">
    <rect x="-10" y="-10" width="360" height="42" rx="10" fill="#1b4965" opacity="0.8" stroke="#00b4d8" />
    <text x="15" y="18" fill="#ffffff" font-family="'Inter', sans-serif" font-size="16" font-weight="900" letter-spacing="2">★ CORE RESOURCES &amp; ACADEMIC FEATURES</text>

    <text x="0" y="120" fill="#ffffff" font-family="'Inter', sans-serif" font-size="64" font-weight="900" letter-spacing="-2">Powerful Academic</text>
    <text x="0" y="195" fill="#00f5d4" font-family="'Inter', sans-serif" font-size="64" font-weight="900" letter-spacing="-2">Utilities &amp; Archives</text>
    <text x="0" y="260" fill="#cbd5e1" font-family="'Inter', sans-serif" font-size="20" font-weight="500" opacity="0.9">
      Access premium high-fidelity academic medical education resources,
    </text>
    <text x="0" y="295" fill="#cbd5e1" font-family="'Inter', sans-serif" font-size="20" font-weight="500" opacity="0.9">
      handwritten lecture notes, interactive slide archives and normal reference metrics.
    </text>

    <!-- Cards Grid representing the 4 columns -->
    <g transform="translate(0, 360)">
      <!-- Card 1: Books -->
      <rect x="0" y="0" width="220" height="280" rx="16" fill="#ffffff" stroke="#e2e8f0" stroke-width="1" />
      <circle cx="50" cy="50" r="26" fill="#0284c7" opacity="0.1" />
      <path d="M 40 42 H 60 V 58 H 40 Z M 48 50 H 52" stroke="#0284c7" stroke-width="2.5" stroke-linecap="round" fill="none" />
      <text x="25" y="120" fill="#0f172a" font-family="'Inter', sans-serif" font-size="20" font-weight="900">Free Books</text>
      <text x="25" y="150" fill="#64748b" font-family="'Inter', sans-serif" font-size="13" font-weight="500">Dive into our premium</text>
      <text x="25" y="170" fill="#64748b" font-family="'Inter', sans-serif" font-size="13" font-weight="500">digital textbooks in</text>
      <text x="25" y="190" fill="#64748b" font-family="'Inter', sans-serif" font-size="13" font-weight="500">hematology &amp; biochemistry.</text>
      <rect x="25" y="225" width="170" height="36" rx="8" fill="#e0f2fe" />
      <text x="110" y="248" fill="#0369a1" font-family="'Inter', sans-serif" font-size="12" font-weight="850" text-anchor="middle">BROWSE EBOOKS</text>

      <!-- Card 2: Notes -->
      <rect x="250" y="0" width="220" height="280" rx="16" fill="#ffffff" stroke="#e2e8f0" stroke-width="1" />
      <circle cx="300" cy="50" r="26" fill="#db2777" opacity="0.1" />
      <path d="M 292 42 H 308 L 312 46 V 58 H 292 Z" stroke="#db2777" stroke-width="2.5" fill="none" />
      <text x="275" y="120" fill="#0f172a" font-family="'Inter', sans-serif" font-size="20" font-weight="900">Academic Notes</text>
      <text x="275" y="150" fill="#64748b" font-family="'Inter', sans-serif" font-size="13" font-weight="500">Master lab values with</text>
      <text x="275" y="170" fill="#64748b" font-family="'Inter', sans-serif" font-size="13" font-weight="500">handwritten, concise</text>
      <text x="275" y="190" fill="#64748b" font-family="'Inter', sans-serif" font-size="13" font-weight="500">syllabus summaries.</text>
      <rect x="275" y="225" width="170" height="36" rx="8" fill="#fdf2f8" />
      <text x="360" y="248" fill="#be185d" font-family="'Inter', sans-serif" font-size="12" font-weight="850" text-anchor="middle">ACCESS NOTES</text>

      <!-- Card 3: Microscope -->
      <rect x="500" y="0" width="220" height="280" rx="16" fill="#ffffff" stroke="#e2e8f0" stroke-width="1" />
      <circle cx="550" cy="50" r="26" fill="#15803d" opacity="0.1" />
      <circle cx="550" cy="48" r="8" stroke="#15803d" stroke-width="2.5" fill="none" />
      <line x1="550" y1="56" x2="550" y2="61" stroke="#15803d" stroke-width="2.5" stroke-linecap="round"/>
      <text x="525" y="120" fill="#0f172a" font-family="'Inter', sans-serif" font-size="18" font-weight="950">Microscope Lab</text>
      <text x="525" y="150" fill="#64748b" font-family="'Inter', sans-serif" font-size="13" font-weight="500">Simulate microscope</text>
      <text x="525" y="170" fill="#64748b" font-family="'Inter', sans-serif" font-size="13" font-weight="500">analyses for multi-cell</text>
      <text x="525" y="190" fill="#64748b" font-family="'Inter', sans-serif" font-size="13" font-weight="500">pathologies instantly.</text>
      <rect x="525" y="225" width="170" height="36" rx="8" fill="#f0fdf4" />
      <text x="610" y="248" fill="#15803d" font-family="'Inter', sans-serif" font-size="12" font-weight="850" text-anchor="middle">START SIMULATOR</text>
    </g>
  </g>

  <!-- Right Side Visual (Stacked Colorful Textbooks and Microscope) -->
  <g transform="translate(1100, 250)">
    <!-- Plate base -->
    <ellipse cx="360" cy="550" rx="380" ry="24" fill="#021424" opacity="0.4" filter="blur(15px)" />
    
    <!-- Stacked Textbooks -->
    <!-- Book 1 Chemistry (Green) -->
    <g transform="translate(80, 420)">
      <path d="M 0 50 L 320 10 L 400 30 L 80 70 Z" fill="url(#book1)" stroke="#065f46" stroke-width="2" />
      <path d="M 80 70 L 400 30 L 400 48 L 80 88 Z" fill="#047857" />
      <path d="M 0 50 L 80 70 L 80 88 L 0 68 Z" fill="#064e3b" />
      <text x="210" y="46" fill="#ffffff" font-family="'Inter', sans-serif" font-size="15" font-weight="900" transform="rotate(-6.5)" opacity="0.95">CLINICAL BIOCHEMISTRY</text>
    </g>

    <!-- Book 2 Microbiology (Blue) -->
    <g transform="translate(90, 360)">
      <path d="M 0 50 L 320 10 L 400 30 L 80 70 Z" fill="url(#book2)" stroke="#1e3a8a" stroke-width="2" />
      <path d="M 80 70 L 400 30 L 400 48 L 80 88 Z" fill="#1d4ed8" />
      <path d="M 0 50 L 80 70 L 80 88 L 0 68 Z" fill="#1e3a8a" />
      <text x="210" y="46" fill="#ffffff" font-family="'Inter', sans-serif" font-size="15" font-weight="900" transform="rotate(-6.5)" opacity="0.95">MEDICAL MICROBIOLOGY</text>
    </g>

    <!-- Book 3 Hematology (Purple) -->
    <g transform="translate(100, 300)">
      <path d="M 0 50 L 320 10 L 400 30 L 80 70 Z" fill="url(#book3)" stroke="#581c87" stroke-width="2" />
      <path d="M 80 70 L 400 30 L 400 48 L 80 88 Z" fill="#7e22ce" />
      <path d="M 0 50 L 80 70 L 80 88 L 0 68 Z" fill="#581c87" />
      <text x="240" y="46" fill="#ffffff" font-family="'Inter', sans-serif" font-size="15" font-weight="900" transform="rotate(-6.5)" opacity="0.95">HEMATOLOGY</text>
    </g>

    <!-- Book 4 Pathology (Magenta-Purple) -->
    <g transform="translate(110, 240)">
      <path d="M 0 50 L 320 10 L 400 30 L 80 70 Z" fill="url(#book4)" stroke="#701a75" stroke-width="2" />
      <path d="M 80 70 L 400 30 L 400 48 L 80 88 Z" fill="#c026d3" />
      <path d="M 0 50 L 80 70 L 80 88 L 0 68 Z" fill="#701a75" />
      <text x="245" y="46" fill="#ffffff" font-family="'Inter', sans-serif" font-size="15" font-weight="900" transform="rotate(-6.5)" opacity="0.95">PATHOLOGY</text>
    </g>

    <!-- High Tech Microscope next to books -->
    <g transform="translate(420, 100)">
      <!-- Main Arm -->
      <path d="M 40 280 C 40 180, 120 160, 140 180 C 160 200, 140 320, 140 360 L 110 380 Z" fill="#ffffff" stroke="#4a5568" stroke-dasharray="1" stroke-width="3" />
      <!-- Top Eyepiece Tubes -->
      <rect x="70" y="60" width="16" height="60" rx="3" fill="#1a202c" stroke="#4a5568" stroke-width="2" transform="rotate(-15 70 60)" />
      <rect x="90" y="55" width="16" height="60" rx="3" fill="#1a202c" stroke="#4a5568" stroke-width="2" transform="rotate(-15 90 55)" />
      <!-- Microscope Head -->
      <polygon points="50,110 130,120 110,165 40,150" fill="#ffffff" stroke="#4a5568" stroke-width="3" />
      
      <!-- Revolving Nosepiece -->
      <ellipse cx="65" cy="175" rx="35" ry="12" fill="#2d3748" stroke="#1a202c" stroke-width="2" transform="rotate(-15 65 175)" />
      <!-- Objective Lenses -->
      <rect x="42" y="185" width="12" height="30" fill="#cbd5e0" stroke="#1a202c" transform="rotate(-5)" />
      <rect x="72" y="185" width="15" height="42" fill="#a0aec0" stroke="#1a202c" transform="rotate(-20)" />

      <!-- Stage Platform -->
      <polygon points="-20,290 120,290 100,314 -40,314" fill="#1a202c" stroke="#2d3748" stroke-width="2.5" />
      
      <!-- Blue specimen slide on stage -->
      <polygon points="20,293 80,293 72,300 12,300" fill="#00b4d8" opacity="0.8" />
      <!-- Condenser Knob -->
      <circle cx="85" cy="340" r="14" fill="#a0aec0" stroke="#4a5568" stroke-width="1.5" />
      <circle cx="85" cy="340" r="6" fill="#4a5568" />

      <!-- Back Focus adjustment gear controls -->
      <circle cx="145" cy="280" r="28" fill="#4d5f75" stroke="#1a202c" stroke-width="2" />
      <circle cx="145" cy="280" r="22" fill="#1d2836" />
      <circle cx="145" cy="280" r="8" fill="#718096" />

      <!-- Base -->
      <path d="M -10,380 L 160,380 C 170,410, 160,430, 150,442 L 0,442 C -10,430, -20,410, -10,380 Z" fill="#ffffff" stroke="#1a202c" stroke-width="3.5" />
      <rect x="-30" y="442" width="220" height="20" rx="5" fill="#1a202c" />
    </g>

    <!-- Fluid Test tubes rack on bottom right -->
    <g transform="translate(180, 410)">
      <!-- Rack Base -->
      <rect x="0" y="50" width="200" height="15" fill="#e2e8f0" stroke="#cbd5e0" stroke-width="2" />
      <rect x="0" y="130" width="200" height="15" fill="#cbd5e0" />
      <!-- Pillars -->
      <rect x="15" y="65" width="10" height="65" fill="#94a3b8" />
      <rect x="175" y="65" width="10" height="65" fill="#94a3b8" />
      <!-- Tubes -->
      <!-- Tube 1 (Red) -->
      <rect x="42" y="15" width="24" height="110" rx="12" fill="none" stroke="#e2e8f0" stroke-width="2.5" />
      <rect x="44" y="55" width="20" height="68" rx="10" fill="#ef4444" opacity="0.8" />
      <!-- Tube 2 (Green) -->
      <rect x="88" y="15" width="24" height="110" rx="12" fill="none" stroke="#e2e8f0" stroke-width="2.5" />
      <rect x="90" y="32" width="20" height="91" rx="10" fill="#10b981" opacity="0.85" />
      <!-- Tube 3 (Blue) -->
      <rect x="134" y="15" width="24" height="110" rx="12" fill="none" stroke="#e2e8f0" stroke-width="2.5" />
      <rect x="136" y="70" width="20" height="53" rx="10" fill="#3b82f6" opacity="0.8" />
    </g>
  </g>
</svg>
