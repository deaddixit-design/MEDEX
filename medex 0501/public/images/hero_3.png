<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" width="100%" height="100%">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#021124" />
      <stop offset="60%" stop-color="#141a29" />
      <stop offset="100%" stop-color="#050a12" />
    </linearGradient>
    <linearGradient id="blueGlow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.3" />
      <stop offset="100%" stop-color="#1d4ed8" stop-opacity="0" />
    </linearGradient>
    <linearGradient id="purpleGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#7e22ce" stop-opacity="0.25" />
      <stop offset="100%" stop-color="#a855f7" stop-opacity="0" />
    </linearGradient>
    <linearGradient id="cardGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#1e293b" />
      <stop offset="100%" stop-color="#0f172a" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1920" height="1080" fill="url(#bg)" />
  <circle cx="960" cy="540" r="600" fill="url(#blueGlow)" filter="blur(120px)" />
  <circle cx="1600" cy="800" r="450" fill="url(#purpleGrad)" filter="blur(95px)" />

  <!-- Grid overlay -->
  <g opacity="0.03" stroke="#ffffff" stroke-width="1">
    <pattern id="grid" width="80" height="80" patternUnits="userSpaceOnUse">
      <rect width="80" height="80" fill="none" />
      <path d="M 80 0 L 0 0 0 80" fill="none" />
    </pattern>
    <rect width="100%" height="100%" fill="url(#grid)" />
  </g>

  <!-- Main Hero Message Header -->
  <g transform="translate(150, 160)">
    <rect x="-10" y="-10" width="310" height="42" rx="10" fill="#1e293b" stroke="#3b82f6" stroke-width="1.5" />
    <text x="15" y="18" fill="#3b82f6" font-family="'Inter', sans-serif" font-size="16" font-weight="950" letter-spacing="2">🧪 DIAGNOSTIC &amp; ACADEMIC HUB</text>

    <text x="0" y="110" fill="#ffffff" font-family="'Inter', sans-serif" font-size="64" font-weight="900" letter-spacing="-2">The Scholar's</text>
    <text x="0" y="185" fill="#3b82f6" font-family="'Inter', sans-serif" font-size="64" font-weight="900" letter-spacing="-2">Content Library</text>
    <text x="0" y="250" fill="#cbd5e1" font-family="'Inter', sans-serif" font-size="20" font-weight="500" opacity="0.9">
      A comprehensive curated collection of books, lecture notes, custom exam guidelines,
    </text>
    <text x="0" y="285" fill="#cbd5e1" font-family="'Inter', sans-serif" font-size="20" font-weight="500" opacity="0.9">
      and interactive studies. Review the industry standard textbooks shared by peers.
    </text>

    <!-- Search bar representation -->
    <g transform="translate(0, 340)">
      <rect x="0" y="0" width="680" height="70" rx="16" fill="#1e293b" stroke="#334155" stroke-width="1.5" />
      <circle cx="38" cy="35" r="10" fill="none" stroke="#94a3b8" stroke-width="3" />
      <line x1="45" y1="42" x2="56" y2="53" stroke="#94a3b8" stroke-width="3" stroke-linecap="round" />
      <text x="80" y="42" fill="#64748b" font-family="'Inter', sans-serif" font-size="18" font-weight="500">Search books, topics, pathology notes...</text>
      
      <!-- Right Action Button inside search bar -->
      <rect x="520" y="10" width="150" height="50" rx="12" fill="#3b82f6" />
      <text x="595" y="41" fill="#ffffff" font-family="'Inter', sans-serif" font-size="15" font-weight="800" text-anchor="middle">SEARCH</text>
    </g>

    <!-- Subject filters pill boxes -->
    <g transform="translate(0, 450)">
      <rect x="0" y="0" width="200" height="50" rx="14" fill="#0f172a" stroke="#12b365" stroke-width="1.5" />
      <text x="100" y="31" fill="#12b365" font-family="'Inter', sans-serif" font-size="13" font-weight="900" text-anchor="middle">Clinical Biochemistry</text>

      <rect x="220" y="0" width="200" height="50" rx="14" fill="#0f172a" stroke="#ef4444" stroke-width="1.5" />
      <text x="320" y="31" fill="#ef4444" font-family="'Inter', sans-serif" font-size="13" font-weight="900" text-anchor="middle">Medical Hematology</text>

      <rect x="440" y="0" width="160" height="50" rx="14" fill="#0f172a" stroke="#eab308" stroke-width="1.5" />
      <text x="520" y="31" fill="#eab308" font-family="'Inter', sans-serif" font-size="13" font-weight="900" text-anchor="middle">Microbiology</text>

      <rect x="620" y="0" width="160" height="50" rx="14" fill="#0f172a" stroke="#a855f7" stroke-width="1.5" />
      <text x="700" y="31" fill="#a855f7" font-family="'Inter', sans-serif" font-size="13" font-weight="900" text-anchor="middle">Histopathology</text>
    </g>
  </g>

  <!-- Dynamic Book Shelf Render on the Right -->
  <g transform="translate(1080, 200)">
    <!-- Base Board -->
    <rect x="-80" y="600" width="840" height="24" rx="6" fill="#1e293b" stroke="#334155" />
    <rect x="-40" y="624" width="760" height="30" fill="#0f172a" opacity="0.8" />

    <!-- Book 1 Specimen Card -->
    <g transform="translate(0, 120)">
      <rect x="0" y="0" width="210" height="440" rx="15" fill="url(#cardGrad)" stroke="#334155" stroke-width="2" />
      <!-- Book Spine Block -->
      <rect x="15" y="15" width="180" height="230" rx="8" fill="#12b365" opacity="0.9" />
      <rect x="28" y="28" width="154" height="204" fill="none" stroke="#ffffff" stroke-width="2" opacity="0.2" />
      
      <!-- Icon Book -->
      <path d="M 85 85 L 125 85 L 125 125 L 85 125 Z" fill="none" stroke="#ffffff" stroke-width="3" />
      <line x1="95" y1="95" x2="115" y2="95" stroke="#ffffff" stroke-width="2" />
      <line x1="95" y1="105" x2="115" y2="105" stroke="#ffffff" stroke-width="2" />
      
      <text x="105" y="170" fill="#ffffff" font-family="'Inter', sans-serif" font-size="13" font-weight="900" text-anchor="middle">Text &amp; Atlas of</text>
      <text x="105" y="190" fill="#ffffff" font-family="'Inter', sans-serif" font-size="13" font-weight="900" text-anchor="middle">Histopathology</text>

      <text x="20" y="285" fill="#ffffff" font-family="'Inter', sans-serif" font-size="16" font-weight="900">Histopathology</text>
      <text x="20" y="315" fill="#64748b" font-family="'Inter', sans-serif" font-size="13" font-weight="500">Dr. R. S. Cotran</text>
      <!-- Size -->
      <rect x="20" y="338" width="80" height="26" rx="5" fill="#111827" />
      <text x="60" y="355" fill="#10b981" font-family="'Inter', sans-serif" font-size="12" font-weight="800" text-anchor="middle">2.35 MB</text>
      
      <!-- Download Arrow Button -->
      <circle cx="165" cy="350" r="18" fill="#3b82f6" />
      <path d="M 165 340 L 165 360 M 158 353 L 165 360 L 172 353" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
    </g>

    <!-- Book 2 Specimen Card -->
    <g transform="translate(245, 120)">
      <rect x="0" y="0" width="210" height="440" rx="15" fill="url(#cardGrad)" stroke="#334155" stroke-width="2" />
      <!-- Book Spine Block -->
      <rect x="15" y="15" width="180" height="230" rx="8" fill="#3b82f6" opacity="0.9" />
      <rect x="28" y="28" width="154" height="204" fill="none" stroke="#ffffff" stroke-width="2" opacity="0.2" />
      
      <!-- Icon Book -->
      <circle cx="105" cy="110" r="18" fill="none" stroke="#ffffff" stroke-width="3" />
      <line x1="95" y1="110" x2="115" y2="110" stroke="#ffffff" stroke-width="2" />

      <text x="105" y="170" fill="#ffffff" font-family="'Inter', sans-serif" font-size="13" font-weight="900" text-anchor="middle">Lehninger Principles</text>
      <text x="105" y="190" fill="#ffffff" font-family="'Inter', sans-serif" font-size="13" font-weight="900" text-anchor="middle">of Biochemistry</text>

      <text x="20" y="285" fill="#ffffff" font-family="'Inter', sans-serif" font-size="18" font-weight="950">Biochemistry</text>
      <text x="20" y="315" fill="#64748b" font-family="'Inter', sans-serif" font-size="13" font-weight="500">David L. Nelson</text>
      <!-- Size -->
      <rect x="20" y="338" width="80" height="26" rx="5" fill="#111827" />
      <text x="60" y="355" fill="#3b82f6" font-family="'Inter', sans-serif" font-size="12" font-weight="800" text-anchor="middle">3.12 MB</text>
      
      <!-- Download Arrow Button -->
      <circle cx="165" cy="350" r="18" fill="#3b82f6" />
      <path d="M 165 340 L 165 360 M 158 353 L 165 360 L 172 353" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
    </g>

    <!-- Book 3 Specimen Card -->
    <g transform="translate(490, 120)">
      <rect x="0" y="0" width="210" height="440" rx="15" fill="url(#cardGrad)" stroke="#334155" stroke-width="2" />
      <!-- Book Spine Block -->
      <rect x="15" y="15" width="180" height="230" rx="8" fill="#a855f7" opacity="0.9" />
      <rect x="28" y="28" width="154" height="204" fill="none" stroke="#ffffff" stroke-width="2" opacity="0.2" />

      <text x="105" y="170" fill="#ffffff" font-family="'Inter', sans-serif" font-size="13" font-weight="900" text-anchor="middle">Harsh Mohan</text>
      <text x="105" y="190" fill="#ffffff" font-family="'Inter', sans-serif" font-size="13" font-weight="900" text-anchor="middle">Textbook of Pathology</text>

      <text x="20" y="285" fill="#ffffff" font-family="'Inter', sans-serif" font-size="18" font-weight="950">Pathology Core</text>
      <text x="20" y="315" fill="#64748b" font-family="'Inter', sans-serif" font-size="13" font-weight="500">Harsh Mohan</text>
      <!-- Size -->
      <rect x="20" y="338" width="80" height="26" rx="5" fill="#111827" />
      <text x="60" y="355" fill="#a855f7" font-family="'Inter', sans-serif" font-size="12" font-weight="800" text-anchor="middle">4.10 MB</text>
      
      <!-- Download Arrow Button -->
      <circle cx="165" cy="350" r="18" fill="#3b82f6" />
      <path d="M 165 340 L 165 360 M 158 353 L 165 360 L 172 353" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
    </g>
  </g>
</svg>
