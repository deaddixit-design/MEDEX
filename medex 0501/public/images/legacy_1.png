<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 1000" width="100%" height="100%">
  <defs>
    <linearGradient id="mainBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#051c38" />
      <stop offset="100%" stop-color="#0a2e5c" />
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#10b981" stop-opacity="0.25" />
      <stop offset="100%" stop-color="#047857" stop-opacity="0" />
    </linearGradient>
  </defs>

  <rect width="800" height="1000" fill="url(#mainBg)" />
  <circle cx="400" cy="500" r="300" fill="url(#glow)" filter="blur(80px)" />

  <!-- Grid Pattern details -->
  <g opacity="0.04" stroke="#ffffff" stroke-width="1">
    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
      <rect width="40" height="40" fill="none" />
      <path d="M 40 0 L 0 0 0 40" fill="none" />
    </pattern>
    <rect width="100%" height="100%" fill="url(#grid)" />
  </g>

  <!-- Illustration content (Academic Graduation / BMLT Professionals) -->
  <g transform="translate(150, 180)">
    <!-- Shield Logo Emblem -->
    <g transform="translate(180, 50)" opacity="0.85">
      <path d="M0 -60 L50 -40 C50 10, 20 60, 0 80 C-20 60, -50 10, -50 -40 Z" fill="none" stroke="#10b981" stroke-width="6" />
      <path d="M 0 -45 L 30 -30 Q 30 5, 0 25 Q -30 5, -30 -30 Z" fill="#047857" opacity="0.3" />
      <!-- Book icon inside -->
      <path d="M -15 -10 L 15 -10 L 15 10 L -15 10 Z" fill="none" stroke="#10b981" stroke-width="3" />
      <line x1="-15" y1="-2" x2="15" y2="-2" stroke="#10b981" stroke-width="2" />
    </g>

    <!-- Star indicators -->
    <g fill="#eab308">
      <polygon points="120,60 125,75 140,75 128,85 132,100 120,90 108,100 112,85 100,75 115,75" transform="scale(0.8) translate(100, 250)"/>
      <polygon points="400,60 405,75 420,75 408,85 412,100 400,90 388,100 392,85 380,75 395,75" transform="scale(0.8) translate(100, 250)"/>
    </g>

    <text x="250" y="270" fill="#ffffff" font-family="'Inter', sans-serif" font-size="36" font-weight="900" text-anchor="middle" letter-spacing="-1">MEDex ACADEMIC LIBRARY</text>
    <text x="250" y="320" fill="#10b981" font-family="'Inter', sans-serif" font-size="20" font-weight="800" text-anchor="middle" letter-spacing="3">ACCELERATE RESEARCH CAREERS</text>

    <!-- Graduation caps floating -->
    <g transform="translate(150, 400)">
      <!-- Cap 1 -->
      <g transform="translate(0, 0) scale(1.4)">
        <polygon points="50,10 100,25 50,40 0,25" fill="#111827" stroke="#334155" stroke-width="2" />
        <rect x="35" y="30" width="30" height="15" fill="#1f2937" />
        <ellipse cx="50" cy="45" rx="15" ry="3" fill="#111827" />
        <!-- Tassel -->
        <path d="M 50,25 Q 75,25 78,42" fill="none" stroke="#eab308" stroke-width="2" />
        <circle cx="78" cy="42" r="3" fill="#eab308" />
      </g>
      
      <!-- Cap 2 (Offsetted) -->
      <g transform="translate(140, -40) scale(1.1) rotate(15)">
        <polygon points="50,10 100,25 50,40 0,25" fill="#1e293b" stroke="#475569" stroke-width="2" />
        <rect x="35" y="30" width="30" height="15" fill="#334155" />
        <ellipse cx="50" cy="45" rx="15" ry="3" fill="#1e293b" />
        <path d="M 50,25 Q 75,25 78,42" fill="none" stroke="#3b82f6" stroke-width="2" />
        <circle cx="78" cy="42" r="3" fill="#3b82f6" />
      </g>
    </g>

    <!-- Open Book Vector representing knowledge -->
    <g transform="translate(120, 560) scale(1.1)">
      <!-- Outer Pages -->
      <path d="M 10 100 C 60 70, 110 80, 130 90 L 130 15 C 110 5, 60 -5, 10 20 Z" fill="#ffffff" stroke="#1e293b" stroke-width="3" />
      <path d="M 130 90 C 150 80, 200 70, 250 100 L 250 20 C 200 -5, 150 5, 130 15 Z" fill="#ffffff" stroke="#1e293b" stroke-width="3" />
      <!-- Book spine page separator -->
      <line x1="130" y1="15" x2="130" y2="90" stroke="#cbd5e1" stroke-width="2" />
      <!-- Lines of writing in book -->
      <line x1="30" y1="35" x2="110" y2="25" stroke="#94a3b8" stroke-width="3" stroke-linecap="round" />
      <line x1="30" y1="50" x2="110" y2="40" stroke="#94a3b8" stroke-width="3" stroke-linecap="round" />
      <line x1="30" y1="65" x2="90" y2="58" stroke="#94a3b8" stroke-width="3" stroke-linecap="round" />
      
      <line x1="150" y1="25" x2="230" y2="35" stroke="#94a3b8" stroke-width="3" stroke-linecap="round" />
      <line x1="150" y1="40" x2="230" y2="50" stroke="#94a3b8" stroke-width="3" stroke-linecap="round" />
      <line x1="150" y1="55" x2="210" y2="62" stroke="#94a3b8" stroke-width="3" stroke-linecap="round" />
    </g>
  </g>

  <!-- Bottom Panel Info text -->
  <rect x="100" y="850" width="600" height="80" rx="15" fill="#0f172a" stroke="#1e293b" stroke-width="2" />
  <text x="400" y="896" fill="#cbd5e1" font-family="'Inter', sans-serif" font-size="16" font-weight="600" text-anchor="middle" opacity="0.9">Designed exclusively to empower BMLT Scholars &amp; Lab Experts.</text>
</svg>
