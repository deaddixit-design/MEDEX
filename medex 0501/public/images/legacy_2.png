<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 1000" width="100%" height="100%">
  <defs>
    <linearGradient id="mainBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#05162a" />
      <stop offset="100%" stop-color="#1e1233" />
    </linearGradient>
    <linearGradient id="violetGlow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#a855f7" stop-opacity="0.25" />
      <stop offset="100%" stop-color="#7e22ce" stop-opacity="0" />
    </linearGradient>
  </defs>

  <rect width="800" height="1000" fill="url(#mainBg)" />
  <circle cx="450" cy="500" r="320" fill="url(#violetGlow)" filter="blur(80px)" />

  <!-- Grid overlay -->
  <g opacity="0.04" stroke="#ffffff" stroke-width="1">
    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
      <rect width="40" height="40" fill="none" />
      <path d="M 40 0 L 0 0 0 40" fill="none" />
    </pattern>
    <rect width="100%" height="100%" fill="url(#grid)" />
  </g>

  <!-- Illustration content (Clinical Diagnostic Laboratory Space) -->
  <g transform="translate(150, 160)">
    <!-- Main Text Header inside -->
    <text x="250" y="100" fill="#ffffff" font-family="'Inter', sans-serif" font-size="34" font-weight="950" text-anchor="middle" letter-spacing="-1">MEDex RESEARCH CENTER</text>
    <text x="250" y="145" fill="#a855f7" font-family="'Inter', sans-serif" font-size="18" font-weight="850" text-anchor="middle" letter-spacing="3.5">HIGH-PRECISION LAB METRICS</text>

    <!-- Lab Testing Station Layout -->
    <g transform="translate(40, 240)">
      <!-- Station Desk shadow -->
      <ellipse cx="210" cy="360" rx="230" ry="20" fill="#000000" opacity="0.5" filter="blur(15px)" />
      
      <!-- Automated Clinical Chemistry Centrifuge Machine -->
      <g transform="translate(60, 60)">
        <!-- Outer drum housing -->
        <rect x="0" y="40" width="300" height="240" rx="20" fill="#f8fafc" stroke="#475569" stroke-width="4.5" />
        <!-- Bottom Dark Bezel base -->
        <rect x="15" y="240" width="270" height="40" rx="10" fill="#1e293b" />
        <!-- LCD Display indicator panel -->
        <rect x="40" y="80" width="220" height="80" rx="10" fill="#0f172a" />
        <!-- Glowing LED metrics inside LCD screen -->
        <text x="60" y="115" fill="#10b981" font-family="'JetBrains Mono', monospace" font-size="16" font-weight="800">SPEED: 4500 RPM</text>
        <text x="60" y="145" fill="#ef4444" font-family="'JetBrains Mono', monospace" font-size="16" font-weight="800">TEMP: 4.0 °C</text>
        <circle cx="210" cy="110" r="14" fill="none" stroke="#2563eb" stroke-width="3" stroke-dasharray="4,2" />
        
        <!-- Status Pilot Lights -->
        <circle cx="215" cy="260" r="6" fill="#10b981" />
        <circle cx="235" cy="260" r="6" fill="#ef4444" opacity="0.4" />
        <circle cx="255" cy="260" r="6" fill="#eab308" opacity="0.4" />

        <!-- Circular Centrifuge Rotor Chamber Lid (Top View Projection) -->
        <ellipse cx="150" cy="40" rx="110" ry="24" fill="#64748b" stroke="#334155" stroke-width="3.5" />
        <ellipse cx="150" cy="40" rx="80" ry="16" fill="#1e293b" stroke="#00b4d8" />
        <!-- Tubes inside centrifuge spinning -->
        <circle cx="110" cy="40" r="8" fill="#e2e8f0" stroke="#ef4444" stroke-width="1.5" />
        <circle cx="190" cy="40" r="8" fill="#e2e8f0" stroke="#ef4444" stroke-width="1.5" />
        <circle cx="150" cy="30" r="8" fill="#e2e8f0" stroke="#3b82f6" stroke-width="1.5" />
        <circle cx="150" cy="50" r="8" fill="#e2e8f0" stroke="#3b82f6" stroke-width="1.5" />
      </g>

      <!-- Erlenmeyer chemical flasks on side table -->
      <g transform="translate(30, 220) scale(0.85)">
        <!-- Liquid in flask 1 -->
        <polygon points="40,20 60,20 60,70 12,170 88,170 40,70" fill="none" stroke="#cbd5e1" stroke-width="4.5" stroke-linejoin="round" />
        <polygon points="21,150 79,150 70,130 30,130" fill="#a855f7" opacity="0.85" />
        <!-- Scale ticks -->
        <line x1="45" y1="110" x2="55" y2="110" stroke="#cbd5e1" stroke-width="2" />
        <line x1="42" y1="130" x2="58" y2="130" stroke="#cbd5e1" stroke-width="2" />
      </g>
    </g>
  </g>

  <!-- Bottom Details Board Panel info -->
  <rect x="100" y="850" width="600" height="80" rx="15" fill="#0f172a" stroke="#1e293b" stroke-width="2" />
  <text x="400" y="896" fill="#cbd5e1" font-family="'Inter', sans-serif" font-size="16" font-weight="600" text-anchor="middle" opacity="0.9">Interactive training tool for modern clinical hematologists.</text>
</svg>
