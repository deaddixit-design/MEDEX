<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 740" width="100%" height="100%">
  <defs>
    <linearGradient id="polaroidBg" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#ffffff"/>
      <stop offset="100%" stop-color="#f8fafc"/>
    </linearGradient>
    <linearGradient id="slideBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1e1b4b"/>
      <stop offset="100%" stop-color="#421a25"/>
    </linearGradient>
  </defs>

  <!-- Polaroid Frame Inner Shadow Edge -->
  <rect width="600" height="740" rx="8" fill="url(#polaroidBg)" stroke="#e2e8f0" stroke-width="6"/>

  <!-- Photo Area -->
  <rect x="40" y="40" width="520" height="520" fill="url(#slideBg)"/>

  <!-- Simulated Microscope Specimen Content (Malaria Smear) -->
  <circle cx="260" cy="260" r="180" fill="none" stroke="#ef4444" stroke-width="2" opacity="0.4" stroke-dasharray="8,4" />

  <!-- Red Blood Cells (RBCs) -->
  <g fill="#f87171" opacity="0.8" stroke="#991b1b" stroke-width="1.8">
    <circle cx="160" cy="180" r="32" stroke-width="1.5" /> <circle cx="160" cy="180" r="12" fill="#1e1b4b" stroke="none" />
    <circle cx="360" cy="190" r="34" stroke-width="1.5" /> <circle cx="360" cy="190" r="13" fill="#1e1b4b" stroke="none" />
    <circle cx="180" cy="340" r="33" stroke-width="1.5" /> <circle cx="180" cy="340" r="12" fill="#1e1b4b" stroke="none" />
    <circle cx="250" cy="130" r="32" stroke-width="1.5" /> <circle cx="250" cy="130" r="12" fill="#1e1b4b" stroke="none" />
    <circle cx="120" cy="265" r="33" stroke-width="1.5" /> <circle cx="120" cy="265" r="12" fill="#1e1b4b" stroke="none" />
    
    <!-- Infected Red Blood Cell with Ring Parasites (Double infection in one cell) -->
    <circle cx="280" cy="280" r="46" stroke="#991b1b" stroke-width="3" />
    <circle cx="280" cy="280" r="16" fill="#1e1b4b" stroke="none" />
  </g>

  <!-- Plasmodium falciparum Ring form parasites inside the center RBC -->
  <g transform="translate(280, 280)">
    <!-- Ring 1 -->
    <g transform="translate(-18, -12)">
      <!-- Delicate chromatin dot -->
      <circle cx="12" cy="0" r="5" fill="#ef4444" />
      <!-- Cytricate ring loop -->
      <ellipse cx="0" cy="0" rx="14" ry="10" fill="none" stroke="#60a5fa" stroke-width="3" transform="rotate(-30)" />
    </g>
    <!-- Ring 2 (Double infection typical for Falciparum) -->
    <g transform="translate(18, 14)">
      <!-- Delicate chromatin dot -->
      <circle cx="12" cy="0" r="5" fill="#ef4444" />
      <!-- Cytricate ring loop -->
      <ellipse cx="0" cy="0" rx="13" ry="9" fill="none" stroke="#60a5fa" stroke-width="3" transform="rotate(25)" />
    </g>
  </g>

  <!-- Plasmodium ring forms in another cell on top right -->
  <g transform="translate(360, 190)">
    <!-- Delicate ring parasite -->
    <g transform="translate(-10, -5) scale(0.65)">
      <circle cx="12" cy="0" r="5" fill="#ef4444" />
      <ellipse cx="0" cy="0" rx="13" ry="9" fill="none" stroke="#60a5fa" stroke-width="3" />
    </g>
  </g>

  <!-- Photo Caption and Label Area -->
  <text x="300" y="615" fill="#0f172a" font-family="'Inter', sans-serif" font-size="28" font-weight="900" text-anchor="middle">PLASMODIUM FALCIPARUM</text>
  <text x="300" y="655" fill="#475569" font-family="'JetBrains Mono', monospace" font-size="16" font-weight="700" text-anchor="middle">MEDex Smear #5088 - magnification 1000x</text>
  <text x="300" y="685" fill="#ef4444" font-family="'Inter', sans-serif" font-size="14" font-weight="950" letter-spacing="3" text-anchor="middle">▲ ACUTE MALARIAL PATHOGEN</text>
</svg>
