<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 740" width="100%" height="100%">
  <defs>
    <linearGradient id="polaroidBg" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#ffffff"/>
      <stop offset="100%" stop-color="#f8fafc"/>
    </linearGradient>
    <linearGradient id="slideBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0a1a2f"/>
      <stop offset="100%" stop-color="#0a2a2f"/>
    </linearGradient>
  </defs>

  <!-- Polaroid Frame Inner Shadow Edge -->
  <rect width="600" height="740" rx="8" fill="url(#polaroidBg)" stroke="#e2e8f0" stroke-width="6"/>

  <!-- Photo Area -->
  <rect x="40" y="40" width="520" height="520" fill="url(#slideBg)"/>

  <!-- Simulated Microscope Specimen Content (Sickle Cell Smear) -->
  <circle cx="260" cy="260" r="180" fill="none" stroke="#eab308" stroke-width="2" opacity="0.4" stroke-dasharray="8,4" />

  <!-- Normal RBCs (Round biconcave disks) -->
  <g fill="#f87171" opacity="0.6" stroke="#991b1b" stroke-width="1.5">
    <circle cx="150" cy="150" r="32" /> <circle cx="150" cy="150" r="11" fill="#0a1a2f" stroke="none" />
    <circle cx="380" cy="160" r="33" /> <circle cx="380" cy="160" r="12" fill="#0a1a2f" stroke="none" />
    <circle cx="160" cy="360" r="31" /> <circle cx="160" cy="360" r="11" fill="#0a1a2f" stroke="none" />
    <circle cx="220" cy="110" r="32" /> <circle cx="220" cy="110" r="11" fill="#0a1a2f" stroke="none" />
  </g>

  <!-- Sickled Red Blood Cells (Drepanocytes - Crescent / Banana shape) -->
  <g fill="#ef4444" opacity="0.9" stroke="#7f1d1d" stroke-width="2">
    <!-- Sickle Cell 1 -->
    <path d="M220,220 C280,180 320,260 280,340 C290,280 270,240 220,220 Z" />
    <!-- Sickle Cell 2 -->
    <path d="M110,240 C140,200 190,210 200,270 C170,250 140,260 110,240 Z" />
    <!-- Sickle Cell 3 (Distinct crescent shape) -->
    <path d="M310,260 C380,260 380,380 300,410 C340,360 350,305 310,260 Z" />
    <!-- Target Sickle Cell 4 -->
    <path d="M190,320 C230,360 210,430 150,420 C180,390 190,350 190,320 Z" />
  </g>

  <!-- Target indicator circle pointing to drepanocyte cell -->
  <circle cx="335" cy="325" r="54" fill="none" stroke="#2563eb" stroke-width="2.5" stroke-dasharray="4,2" />
  <!-- Indicator arrow marker -->
  <path d="M395,265 L365,295 M365,295 L378,295 M365,295 L365,282" fill="none" stroke="#2563eb" stroke-width="2.5" stroke-linecap="round" />

  <!-- Photo Caption and Label Area -->
  <text x="300" y="615" fill="#0f172a" font-family="'Inter', sans-serif" font-size="28" font-weight="900" text-anchor="middle">SICKLE CELL ANEMIA</text>
  <text x="300" y="655" fill="#475569" font-family="'JetBrains Mono', monospace" font-size="16" font-weight="700" text-anchor="middle">MEDex Smear #3024 - Drepanocyte Specimen</text>
  <text x="300" y="685" fill="#eab308" font-family="'Inter', sans-serif" font-size="14" font-weight="950" letter-spacing="3" text-anchor="middle">▲ DIAGNOSTIC HEMOGLOBIN OPACITIES</text>
</svg>
