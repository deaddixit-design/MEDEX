<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" width="100%" height="100%">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0a192f" />
      <stop offset="50%" stop-color="#0f3460" />
      <stop offset="100%" stop-color="#16213e" />
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#00b4d8" stop-opacity="0.8"/>
      <stop offset="100%" stop-color="#0077b6" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="greenGlow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#00f5d4" stop-opacity="0.3" />
      <stop offset="100%" stop-color="#01c7b1" stop-opacity="0" />
    </linearGradient>
    <linearGradient id="laptopBezel" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#2d3748" />
      <stop offset="100%" stop-color="#1a202c" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1920" height="1080" fill="url(#bg)" />
  <circle cx="200" cy="200" r="400" fill="url(#greenGlow)" filter="blur(80px)" />
  <circle cx="1700" cy="800" r="500" fill="url(#glow)" filter="blur(100px)" />

  <!-- Grid overlay -->
  <g opacity="0.05" stroke="#ffffff" stroke-width="1">
    <pattern id="grid" width="80" height="80" patternUnits="userSpaceOnUse">
      <rect width="80" height="80" fill="none" />
      <path d="M 80 0 L 0 0 0 80" fill="none" />
    </pattern>
    <rect width="100%" height="100%" fill="url(#grid)" />
  </g>

  <!-- Title Section -->
  <g transform="translate(150, 220)">
    <!-- MEDex Logo Styled -->
    <g transform="scale(1.5)">
      <rect x="-10" y="-10" width="180" height="80" rx="15" fill="#1e293b" opacity="0.6" stroke="#00b4d8" stroke-width="2"/>
      <text x="15" y="45" fill="#00b4d8" font-family="'Inter', sans-serif" font-size="44" font-weight="900" letter-spacing="-1">MED</text>
      <text x="115" y="45" fill="#00f5d4" font-family="'Inter', sans-serif" font-size="44" font-weight="950" font-style="italic">ex</text>
    </g>

    <text x="0" y="160" fill="#ffffff" font-family="'Inter', sans-serif" font-size="80" font-weight="900" letter-spacing="-2">MLT DESK</text>
    <text x="0" y="240" fill="#00f5d4" font-family="'Inter', sans-serif" font-size="40" font-weight="800" letter-spacing="1">Academic &amp; Diagnostic MD Portal</text>
    <text x="0" y="320" fill="#e2e8f0" font-family="'Inter', sans-serif" font-size="24" font-weight="500" width="800" opacity="0.8">
      Your all-in-one customized laboratory workspace. Explore interactive
    </text>
    <text x="0" y="360" fill="#e2e8f0" font-family="'Inter', sans-serif" font-size="24" font-weight="500" opacity="0.8">
      hematology parameters, histology slide cases, biochemistry scales, and books.
    </text>

    <!-- Bullets -->
    <g transform="translate(0, 430)">
      <rect x="0" y="0" width="300" height="70" rx="15" fill="#00b4d8" opacity="0.15" />
      <circle cx="35" cy="35" r="10" fill="#00b4d8" />
      <text x="65" y="42" fill="#ffffff" font-family="'Inter', sans-serif" font-size="20" font-weight="700">SPECIMEN ANALYZER</text>

      <rect x="330" y="0" width="300" height="70" rx="15" fill="#00f5d4" opacity="0.15" />
      <circle cx="365" cy="35" r="10" fill="#00f5d4" />
      <text x="395" y="42" fill="#ffffff" font-family="'Inter', sans-serif" font-size="20" font-weight="700">CASE ARCHIVE</text>
    </g>
  </g>

  <!-- Laptop Mockup Representation -->
  <g transform="translate(1000, 180)">
    <!-- Base Shadow -->
    <ellipse cx="400" cy="720" rx="420" ry="30" fill="#000000" opacity="0.6" filter="blur(20px)" />

    <!-- Screen Bezel -->
    <rect x="50" y="100" width="700" height="500" rx="24" fill="url(#laptopBezel)" stroke="#4a5568" stroke-width="4" />
    
    <!-- Screen Glass -->
    <rect x="70" y="120" width="660" height="440" fill="#0b0f19" />

    <!-- Mock Screen Content -->
    <!-- Screen Header -->
    <rect x="70" y="120" width="660" height="40" fill="#1e293b" />
    <circle cx="95" cy="140" r="5" fill="#ef4444" />
    <circle cx="110" cy="140" r="5" fill="#f59e0b" />
    <circle cx="125" cy="140" r="5" fill="#10b981" />
    <text x="340" y="146" fill="#94a3b8" font-family="'Inter', sans-serif" font-size="14" font-weight="700" text-anchor="middle">MEDex MLT Specimen Identifier</text>

    <!-- Side Panel -->
    <rect x="85" y="180" width="180" height="360" rx="12" fill="#111827" />
    <text x="105" y="215" fill="#94a3b8" font-family="'Inter', sans-serif" font-size="12" font-weight="800">SPECIMEN DECK</text>
    
    <!-- Item 1 -->
    <rect x="95" y="235" width="160" height="40" rx="8" fill="#1e293b" stroke="#00b4d8" />
    <circle cx="120" cy="255" r="12" fill="#991b1b" opacity="0.3" stroke="#ef4444" stroke-width="1.5" />
    <circle cx="120" cy="255" r="4" fill="#7f1d1d" />
    <text x="145" y="260" fill="#ffffff" font-family="'Inter', sans-serif" font-size="11" font-weight="700">Neutrophil Cell</text>

    <!-- Item 2 -->
    <rect x="95" y="285" width="160" height="40" rx="8" fill="#111827" stroke="#374151" />
    <circle cx="120" cy="305" r="12" fill="#065f46" opacity="0.3" stroke="#34d399" stroke-width="1.5" />
    <text x="145" y="310" fill="#94a3b8" font-family="'Inter', sans-serif" font-size="11" font-weight="700">Eosinophil Cell</text>

    <!-- Active Analyzer Center Screen -->
    <rect x="280" y="180" width="430" height="360" rx="12" fill="#1e293b" />
    <!-- Outer Scope Circle -->
    <circle cx="495" cy="330" r="100" fill="#111827" stroke="#00f5d4" stroke-width="2.5" />
    <!-- Grid -->
    <line x1="395" y1="330" x2="595" y2="330" stroke="#00f5d4" stroke-width="1" stroke-dasharray="2,2" opacity="0.5" />
    <line x1="495" y1="230" x2="495" y2="430" stroke="#00f5d4" stroke-width="1" stroke-dasharray="2,2" opacity="0.5" />
    <circle cx="495" cy="330" r="110" fill="none" stroke="#2a4365" stroke-dasharray="6,4" />

    <!-- Red Blood Cells -->
    <circle cx="435" cy="310" r="14" fill="#b91c1c" opacity="0.8" />
    <circle cx="435" cy="310" r="6" fill="#7f1d1d" opacity="0.8" />
    <circle cx="545" cy="290" r="15" fill="#b91c1c" opacity="0.8" />
    <circle cx="545" cy="290" r="7" fill="#7f1d1d" opacity="0.8" />
    <circle cx="465" cy="385" r="15" fill="#b91c1c" opacity="0.8" />
    <circle cx="465" cy="385" r="7" fill="#7f1d1d" opacity="0.8" />
    <!-- Active Neutrophil Cell -->
    <circle cx="495" cy="330" r="28" fill="#a855f7" opacity="0.4" stroke="#d8b4fe" stroke-width="2" />
    <path d="M485,325 Q480,315 490,315 Q495,315 492,328 Q502,325 508,335 Q500,345 490,340 Z" fill="#3b0764" />

    <text x="295" y="520" fill="#00f5d4" font-family="'Inter', sans-serif" font-size="11" font-weight="800">AUTOMATIC ALIGN: ON</text>
    <text x="695" y="520" fill="#94a3b8" font-family="'Inter', sans-serif" font-size="11" font-weight="800" text-anchor="end">ZOOM: 1000X</text>

    <!-- Base / Keyboard Joint -->
    <polygon points="120,600 680,600 710,630 90,630" fill="#4a5568" stroke="#1a202c" stroke-width="2" />
    <!-- Lower Body -->
    <rect x="70" y="630" width="660" height="15" rx="5" fill="#cbd5e0" />
    <rect x="350" y="630" width="100" height="6" rx="3" fill="#4a5568" />
  </g>
</svg>
