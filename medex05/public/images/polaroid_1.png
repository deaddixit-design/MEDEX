<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 740" width="100%" height="100%">
  <defs>
    <linearGradient id="polaroidBg" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#ffffff"/>
      <stop offset="100%" stop-color="#f8fafc"/>
    </linearGradient>
    <linearGradient id="slideBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1e1b4b"/>
      <stop offset="100%" stop-color="#311042"/>
    </linearGradient>
  </defs>

  <!-- Polaroid Frame Inner Shadow Edge -->
  <rect width="600" height="740" rx="8" fill="url(#polaroidBg)" stroke="#e2e8f0" stroke-width="6"/>

  <!-- Photo Area -->
  <rect x="40" y="40" width="520" height="520" fill="url(#slideBg)"/>

  <!-- Simulated Microscope Specimen Content (Normal Blood Smear - Segmented Neutrophil) -->
  <circle cx="260" cy="260" r="180" fill="none" stroke="#2563eb" stroke-width="2.5" opacity="0.4" stroke-dasharray="8,4" />
  
  <!-- Red Blood Cells (RBCs) -->
  <g fill="#ef4444" opacity="0.75" stroke="#7f1d1d" stroke-width="1.5">
    <!-- Row of circles representing classic biconcave disks of blood cells -->
    <circle cx="160" cy="180" r="32" /> <circle cx="160" cy="180" r="12" fill="#311042" stroke="none" />
    <circle cx="360" cy="190" r="34" /> <circle cx="360" cy="190" r="13" fill="#311042" stroke="none" />
    <circle cx="180" cy="340" r="33" /> <circle cx="180" cy="340" r="12" fill="#311042" stroke="none" />
    <circle cx="340" cy="320" r="31" /> <circle cx="340" cy="320" r="11" fill="#311042" stroke="none" />
    <circle cx="250" cy="130" r="32" /> <circle cx="250" cy="130" r="12" fill="#311042" stroke="none" />
    <circle cx="120" cy="265" r="33" /> <circle cx="120" cy="265" r="12" fill="#311042" stroke="none" />
  </g>

  <!-- Segmented Neutrophil Cell in Center (Purple active lobes) -->
  <g transform="translate(270, 260)">
    <!-- Cytoplasm of the WBC -->
    <circle cx="0" cy="0" r="62" fill="#c084fc" opacity="0.55" stroke="#a855f7" stroke-width="2"/>
    <!-- Intracellular Granules -->
    <g fill="#d8b4fe">
      <circle cx="-25" cy="-20" r="2.5"/> <circle cx="20" cy="-30" r="3"/>
      <circle cx="30" cy="20" r="2"/> <circle cx="-35" cy="15" r="3"/>
      <circle cx="-10" cy="-35" r="2"/> <circle cx="-5" cy="35" r="2.5"/>
    </g>
    <!-- Multi-lobed Nucleus connected by thin strands (Classic Neutrophil) -->
    <!-- Lobe 1 -->
    <path d="M-25,-12 C-38,-20 -25,-42 -12,-30 C-5,-20 -15,-5 -25,-12 Z" fill="#3b0764"/>
    <!-- Lobe 2 -->
    <path d="M22,-8 C35,-22 42,2 25,8 C12,14 10,-2 22,-8 Z" fill="#3b0764"/>
    <!-- Lobe 3 -->
    <path d="M-8,22 C-20,38 12,38 8,20 C5,10 -2,12 -8,22 Z" fill="#3b0764"/>
    <!-- Connecting strands -->
    <path d="M-20,-22 Q-5,-22 15,-10 M25,2 Q15,22 2,22 M-8,24 Q-22,12 -23,-12" fill="none" stroke="#3b0764" stroke-width="4" stroke-linecap="round"/>
  </g>

  <!-- Platelets (Small purple fragments) -->
  <g fill="#a855f7" stroke="#6b21a8" stroke-width="1">
    <polygon points="110,120 115,116 118,122 112,124" />
    <polygon points="390,140 395,138 396,143 392,144" />
    <polygon points="310,390 316,386 319,392 312,394" />
  </g>

  <!-- Photo Caption and Label Area -->
  <text x="300" y="615" fill="#0f172a" font-family="'Inter', sans-serif" font-size="28" font-weight="900" text-anchor="middle">SEGMENTED NEUTROPHIL</text>
  <text x="300" y="655" fill="#475569" font-family="'JetBrains Mono', monospace" font-size="16" font-weight="700" text-anchor="middle">MEDex Smear #4010 - magnification 1000x</text>
  <text x="300" y="685" fill="#10b981" font-family="'Inter', sans-serif" font-size="14" font-weight="950" letter-spacing="3" text-anchor="middle">● NORMAL PERIPHERAL BLOOD</text>
</svg>
